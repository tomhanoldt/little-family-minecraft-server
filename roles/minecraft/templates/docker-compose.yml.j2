# Auto-generated by Ansible - manual changes will be lost on the next deploy.
services:
  mc:
    image: itzg/minecraft-server:java21@sha256:43685ce3678cd9623b55004a477398caa144d2d4c574f69a2eca15a6da5ea405
    container_name: minecraft
    restart: unless-stopped
    tty: true
    stdin_open: true
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      # The image's entrypoint starts as root to chown /data and then drops
      # to UID/GID below via setuid/setgid - these are what that handoff
      # needs, nothing more (no NET_RAW, NET_BIND_SERVICE, etc.).
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
      - FOWNER
      - FSETID
      - KILL
      - SETPCAP
      - SETFCAP
    ports:
      - "25565:25565"
{% if enable_bedrock_support %}
      - "19132:19132/udp"
{% endif %}
    environment:
      EULA: "TRUE"
      TYPE: "{{ mc_type }}"
      VERSION: "{{ mc_version }}"
      MEMORY: "{{ mc_memory }}"
      TZ: "{{ timezone }}"
      DIFFICULTY: "{{ mc_difficulty }}"
      MOTD: "{{ mc_motd }}"
      MAX_PLAYERS: "{{ mc_max_players }}"
      VIEW_DISTANCE: "{{ mc_view_distance }}"
      UID: "1000"
      GID: "1000"
      # Security: only whitelisted, verified accounts can join
      ONLINE_MODE: "TRUE"
      ENFORCE_WHITELIST: "TRUE"
      WHITELIST: "{{ mc_whitelist | map(attribute='name') | join(',') }}"
      OPS: "{{ mc_ops | join(',') }}"
      # No LAN broadcast / no public server listing
      SNOOPER_ENABLED: "FALSE"
      # RCON for mc-backup (save-all/save-off/save-on around backups).
      # Without its own password the image would otherwise fall back to an insecure default.
      ENABLE_RCON: "TRUE"
      RCON_PASSWORD: "{{ mc_rcon_password }}"
{% if enable_bedrock_support %}
      # The "floodgate" project on Modrinth is an unrelated Fabric/NeoForge mod -
      # the real Paper-compatible Floodgate plugin isn't on Modrinth at all, only
      # on GeyserMC's own download server, so it's fetched directly here instead.
      PLUGINS: "https://download.geysermc.org/v2/projects/floodgate/versions/latest/builds/latest/downloads/spigot"
{% endif %}
      # Auto-load plugins from Modrinth (always current + compatible with the MC version)
      # Geyser only ever publishes beta-tagged builds on Modrinth, never
      # "release" - without this, resolution fails outright.
      MODRINTH_PROJECTS_DEFAULT_VERSION_TYPE: "beta"
      MODRINTH_PROJECTS: |
{% if enable_bedrock_support %}
        geyser
{% endif %}
{% if enable_essentials %}
        essentialsx
{% endif %}
{% if enable_coreprotect %}
        coreprotect
{% endif %}
{% if enable_anti_grief_claims %}
        griefprevention
{% endif %}
{% if enable_chat_filter %}
        chat_filter
{% endif %}
{% if enable_discord_bridge %}
        discordsrv
{% endif %}
      # Only auto-select based on plugins when no version is pinned -
      # otherwise VERSION_FROM_MODRINTH_PROJECTS would override the manually set mc_version.
      VERSION_FROM_MODRINTH_PROJECTS: "{{ 'true' if mc_version | upper == 'LATEST' else 'false' }}"
    volumes:
      - "{{ mc_data_dir }}/data:/data"
    healthcheck:
      test: ["CMD", "mc-health"]
      start_period: 60s
      interval: 15s
      retries: 3

{% if enable_backup %}
  mc-backup:
    image: itzg/mc-backup:2026.6.2@sha256:324971bd9b77867c5ee8ca510d071e63b96402995c0fb027b270e72f893140db
    container_name: minecraft-backup
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      # crond itself needs to run as root (image requirement), and dropping
      # privileges to CRON_BACKUP_UID for the actual backup jobs needs these.
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
      - FOWNER
      - FSETID
      - KILL
      - SETPCAP
      - SETFCAP
    environment:
      BACKUP_INTERVAL: "{{ backup_interval }}"
      PRUNE_BACKUPS_DAYS: "{{ backup_retention_days }}"
      RCON_HOST: mc
      RCON_PASSWORD: "{{ mc_rcon_password }}"
      TZ: "{{ timezone }}"
      # crond itself must stay root (image requirement), but the actual backup
      # commands it spawns run as this uid instead of root.
      CRON_BACKUP_UID: "1000"
    volumes:
      - "{{ mc_data_dir }}/data:/data:ro"
      - "{{ mc_data_dir }}/backups:/backups"
    depends_on:
      - mc
{% endif %}
