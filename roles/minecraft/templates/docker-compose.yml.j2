# Auto-generated by Ansible - manual changes will be lost on the next deploy.
services:
  mc:
    image: itzg/minecraft-server:java21@sha256:43685ce3678cd9623b55004a477398caa144d2d4c574f69a2eca15a6da5ea405
    container_name: minecraft
    restart: unless-stopped
    tty: true
    stdin_open: true
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      # The image's entrypoint starts as root to chown /data and then drops
      # to UID/GID below via setuid/setgid - these are what that handoff
      # needs, nothing more (no NET_RAW, NET_BIND_SERVICE, etc.).
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
      - FOWNER
      - FSETID
      - KILL
      - SETPCAP
      - SETFCAP
    # MEMORY below only caps the JVM heap - off-heap usage (metaspace, direct
    # buffers, native libs) isn't bounded by that, so the container limit
    # needs headroom above it or a legitimate heap-sized JVM gets OOM-killed.
    mem_limit: "{{ mc_container_mem_limit }}"
    mem_reservation: "{{ mc_memory }}"
    pids_limit: 2048
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "5"
    ports:
      - "25565:25565"
{% if enable_bedrock_support %}
      - "19132:19132/udp"
{% endif %}
{% if enable_home_assistant_stats %}
      # Loopback-only (127.0.0.1), never reaches UFW or the tailnet - lets
      # the stats server script on the host itself talk real RCON without
      # shelling into the container. See roles/minecraft/tasks/ha_stats.yml.
      - "127.0.0.1:25575:25575"
{% endif %}
    environment:
      EULA: "TRUE"
      TYPE: "{{ mc_type }}"
      VERSION: "{{ mc_version }}"
      MEMORY: "{{ mc_memory }}"
      TZ: "{{ timezone }}"
      DIFFICULTY: "{{ mc_difficulty }}"
      # The itzg image's variable for this is "MODE", not "GAMEMODE" -
      # verified against itzg's own docs after GAMEMODE silently did nothing.
      MODE: "{{ mc_gamemode }}"
      MOTD: "{{ mc_motd }}"
      MAX_PLAYERS: "{{ mc_max_players }}"
      VIEW_DISTANCE: "{{ mc_view_distance }}"
      # CUSTOM_SERVER_PROPERTIES only accepts strict KEY=VALUE lines - no
      # comments inside the block itself, confirmed the hard way (it fails
      # the whole property update, not just skip the bad line).
      # - spawn-protection=0: vanilla's own spawn radius (default 16)
      #   silently reverts breaks/placements for non-ops, independent of
      #   and redundant with GriefPrevention's own claims (docs/plugins.md).
      # - force-gamemode=true: without this, MODE below only sets the
      #   default for brand-new players - anyone who already joined before
      #   keeps their old mode forever. This forces everyone to MODE on
      #   every join/respawn, matching "everyone just plays in Creative."
      CUSTOM_SERVER_PROPERTIES: |
        spawn-protection=0
        force-gamemode=true
      UID: "1000"
      GID: "1000"
      # Security: only whitelisted, verified accounts can join
      ONLINE_MODE: "TRUE"
      ENFORCE_WHITELIST: "TRUE"
      # WHITELIST_FILE/OPS_FILE (not the plain WHITELIST/OPS name-list vars)
      # deliberately - those resolve names via a live PlayerDB/Mojang call
      # inside the container with no skip-on-failure mode, and a single bad
      # name crash-loops the whole server. whitelist.json/ops.json are
      # pre-resolved and written by Ansible instead - see
      # roles/minecraft/tasks/resolve_players.yml.
      WHITELIST_FILE: "/managed-config/whitelist.json"
      EXISTING_WHITELIST_FILE: "SKIP"
      OPS_FILE: "/managed-config/ops.json"
      EXISTING_OPS_FILE: "SKIP"
{% if enable_bedrock_support %}
      # Bedrock/Floodgate players have no Mojang chat-signing key, so Java's
      # "secure chat" enforcement silently disables their chat entirely
      # ("Chat disabled due to missing profile public key") - a confirmed,
      # known Geyser/Floodgate incompatibility, not a config mistake. This
      # also disables Mojang's built-in chat-reporting tool - moderation
      # relies on ChatFilter + CoreProtect instead (see docs/security.md).
      ENFORCE_SECURE_PROFILE: "FALSE"
{% endif %}
      # No LAN broadcast / no public server listing
      SNOOPER_ENABLED: "FALSE"
      # RCON for mc-backup (save-all/save-off/save-on around backups).
      # Without its own password the image would otherwise fall back to an insecure default.
      ENABLE_RCON: "TRUE"
      RCON_PASSWORD: "{{ mc_rcon_password }}"
{% if enable_bedrock_support %}
      # The "floodgate" project on Modrinth is an unrelated Fabric/NeoForge mod -
      # the real Paper-compatible Floodgate plugin isn't on Modrinth at all, only
      # on GeyserMC's own download server, so it's fetched directly here instead.
      PLUGINS: "https://download.geysermc.org/v2/projects/floodgate/versions/latest/builds/latest/downloads/spigot"
{% endif %}
      # Auto-load plugins from Modrinth (always current + compatible with the MC version)
      # Geyser only ever publishes beta-tagged builds on Modrinth, never
      # "release" - without this, resolution fails outright.
      # ViaVersion: Geyser is always fetched at latest and now speaks a newer
      # Java protocol (26.x) than this deliberately-pinned server (1.21.4 -
      # CoreProtect/ChatFilter have no 26.x build yet - see docs/plugins.md).
      # ViaVersion bridges that gap without bumping the server version.
      MODRINTH_PROJECTS_DEFAULT_VERSION_TYPE: "beta"
      MODRINTH_PROJECTS: |
{% if enable_bedrock_support %}
        geyser
        viaversion
{% endif %}
{% if enable_essentials %}
        essentialsx
{% endif %}
{% if enable_coreprotect %}
        coreprotect
{% endif %}
{% if enable_anti_grief_claims %}
        griefprevention
{% endif %}
{% if enable_chat_filter %}
        chat_filter
{% endif %}
{% if enable_skins_restorer %}
        skinsrestorer
{% endif %}
      # Only auto-select based on plugins when no version is pinned -
      # otherwise VERSION_FROM_MODRINTH_PROJECTS would override the manually set mc_version.
      VERSION_FROM_MODRINTH_PROJECTS: "{{ 'true' if mc_version | upper == 'LATEST' else 'false' }}"
    volumes:
      - "{{ mc_data_dir }}/data:/data"
      - "{{ mc_data_dir }}/managed:/managed-config:ro"
    healthcheck:
      test: ["CMD", "mc-health"]
      start_period: 60s
      interval: 15s
      retries: 3

{% if enable_backup %}
  mc-backup:
    image: itzg/mc-backup:2026.6.2@sha256:324971bd9b77867c5ee8ca510d071e63b96402995c0fb027b270e72f893140db
    container_name: minecraft-backup
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      # crond itself needs to run as root (image requirement), and dropping
      # privileges to CRON_BACKUP_UID for the actual backup jobs needs these.
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
      - FOWNER
      - FSETID
      - KILL
      - SETPCAP
      - SETFCAP
    # Compressing a large world folder can spike memory briefly - generous
    # on purpose, this container just isn't expected to ever need more.
    mem_limit: "1g"
    pids_limit: 128
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "5"
    environment:
      BACKUP_INTERVAL: "{{ backup_interval }}"
      PRUNE_BACKUPS_DAYS: "{{ backup_retention_days }}"
      RCON_HOST: mc
      RCON_PASSWORD: "{{ mc_rcon_password }}"
      TZ: "{{ timezone }}"
      # crond itself must stay root (image requirement), but the actual backup
      # commands it spawns run as this uid instead of root.
      CRON_BACKUP_UID: "1000"
    volumes:
      - "{{ mc_data_dir }}/data:/data:ro"
      - "{{ mc_data_dir }}/backups:/backups"
    depends_on:
      - mc
{% endif %}
