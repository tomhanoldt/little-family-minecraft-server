---
# =============================================================
# GENERAL
# =============================================================
timezone: "Europe/Berlin"

# =============================================================
# TAILSCALE
# =============================================================
# Generate an auth key at: https://login.tailscale.com/admin/settings/keys
# (best as "reusable" + "ephemeral: false", optionally tagged)
tailscale_authkey: "tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX"
tailscale_hostname: "little-family-mincraft-server"
# If already manually connected to Tailscale, you can leave tailscale_authkey
# empty ("") - the role will then just check that tailscale is running.

# =============================================================
# FIREWALL
# =============================================================
# Tailscale always uses the CGNAT range 100.64.0.0/10 internally.
# This means the Minecraft port is ONLY reachable from the tailnet,
# never from the regular internet or even the home network (unless desired).
allowed_source_cidr: "100.64.0.0/10"
# If your child should also be able to play from the home WiFi (without Tailscale),
# add your LAN subnet here too, e.g. "192.168.1.0/24"
additional_allowed_cidrs: []

# =============================================================
# MINECRAFT SERVER
# =============================================================
mc_data_dir: /opt/minecraft
mc_version: "1.21.4"          # or "LATEST"
mc_type: "PAPER"
mc_memory: "6G"                # realistic value for ~8 players on 16GB total RAM
# Container-level memory limit, not the JVM heap (that's mc_memory above).
# Needs headroom above mc_memory for JVM off-heap usage (metaspace, direct
# buffers, native libs) - keep ~1G above mc_memory. Total budget check for a
# 16GB box: OS ~1G + this 7G + mc-backup's 1G leaves ~7G of slack.
mc_container_mem_limit: "7G"
mc_difficulty: "easy"
mc_motd: "§bFamily server – invited friends only! §d<3"
mc_max_players: 8
mc_view_distance: 8

# Whitelist is a MANDATORY part of this setup (no public access).
# Enter the Minecraft names of your daughter + her friends.
# Java names get their UUID pre-resolved via Mojang's API at deploy time
# (fails the Ansible run cleanly on a typo, rather than crashing the live
# server - see roles/minecraft/tasks/resolve_players.yml). Bedrock/Floodgate
# names (a "." prefix, e.g. ".aliceplays") can't be pre-resolved - they're
# skipped here with a warning and need '/fwhitelist add <name>' in-game/
# console after their FIRST connection - see docs/plugins.md.
mc_whitelist:
  - name: "DaughterMCName"
  - name: "FriendMCName1"
  - name: "FriendMCName2"

# Who gets admin commands (e.g. /gamemode, /tp)? Usually just your daughter or yourself.
# Same Java/Bedrock split as mc_whitelist above.
mc_ops:
  - "DaughterMCName"

# =============================================================
# BEDROCK / DEVICE COMPATIBILITY
# =============================================================
# As long as it's unclear which devices the friends will play on,
# leave this on - costs almost no performance, but makes every device compatible.
enable_bedrock_support: true

# =============================================================
# SAFETY / MODERATION - feel free to toggle these on/off
# =============================================================
enable_essentials: true          # Homes, spawn protection, basic commands
enable_anti_grief_claims: true   # GriefPrevention: kids protect their own build area
enable_coreprotect: true         # Logging + rollback option in case of grief/accidents
enable_chat_filter: true          # ChatFilter: blocks links/scam-list content + spam
                                  # (ChatControl was dropped: verified via local test that its
                                  # free Modrinth build has no release for MC 1.21.4, only up to
                                  # ~1.20.1, and crash-loops the server if forced. ChatFilter's
                                  # default config only *registers* its filters without enabling
                                  # them, so roles/minecraft/files/chatfilter-filter.yml pre-seeds
                                  # it with the website/IP filter + GamerSafer's moderation list
                                  # switched on - verified this survives restarts unmodified.)
enable_discord_bridge: false     # DiscordSRV: mirror chat into a private Discord channel
discord_webhook_url: ""          # only needed if enable_discord_bridge: true

# Limit play times (optional). If enabled, a cronjob starts/stops
# the server automatically only within this time window.
enable_playtime_schedule: false
playtime_start_cron: "0 14 * * *"   # start daily at 14:00
playtime_stop_cron: "0 19 * * *"    # stop daily at 19:00

# =============================================================
# BACKUP
# =============================================================
enable_backup: true
backup_interval: "24h"
backup_retention_days: 7
# Password mc-backup uses over RCON to run "save-off/save-all" before each backup.
# Freely chosen/generated, doesn't need to be known anywhere else -
# don't confuse this with real Minecraft account passwords.
mc_rcon_password: "CHANGE_ME_generate_a_random_string"
